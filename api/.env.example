DATABASE_URL="postgresql://netwealth:netwealth@localhost:5432/netwealth?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"
PORT=3001

# Set BANK_PROVIDER=mock to use the built-in mock provider (default when unset).
# Swap to "mono" or "okra" once real credentials are available.
BANK_PROVIDER="mock"
MONO_SECRET_KEY=""
OKRA_SECRET_KEY=""

# Shared secret a real provider would sign webhook calls with. Leave blank in
# dev; the mock provider's simulated webhook works without it.
BANK_WEBHOOK_SECRET=""

# Periodic fallback sync (every 5 min) for banks that don't push webhooks
# reliably. Set to "false" to disable.
SCHEDULED_SYNC_ENABLED="true"

# Set CATEGORIZER=mock to use the built-in rule-based categorizer (default when unset).
# Swap to "openai" once an API key is available.
CATEGORIZER="mock"
OPENAI_API_KEY=""

# Set AI_ADVISOR=rule-based to use the built-in deterministic insights engine
# (default when unset). Swap to "openai" once an API key is available.
AI_ADVISOR="rule-based"

# Set ALERT_CHANNEL=mock to log spending alerts instead of sending them
# (default when unset). Swap to "telegram" once a bot token is available.
ALERT_CHANNEL="mock"
TELEGRAM_BOT_TOKEN=""
