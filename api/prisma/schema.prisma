generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountKind {
  ASSET
  LIABILITY
}

enum AccountType {
  BANK
  CASH
  CRYPTO
  STOCK
  MUTUAL_FUND
  PROPERTY
  VEHICLE
  LOAN
  CREDIT_FACILITY
  MORTGAGE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  ABANDONED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Spending alerts (WhatsApp/Telegram) preferences.
  alertsEnabled  Boolean @default(false)
  telegramChatId String?

  accounts     Account[]
  categories   Category[]
  budgets      Budget[]
  goals        Goal[]
  alerts       Alert[]
}

model Alert {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  channel   String
  message   String
  insightId String?
  sentAt    DateTime @default(now())

  @@index([userId])
}

model Account {
  id            String      @id @default(uuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  kind          AccountKind
  type          AccountType
  currency      String      @default("NGN")
  balance       Decimal     @default(0) @db.Decimal(18, 2)

  // Set when this account is linked via an open banking provider (Mono/Okra/etc).
  provider      String?
  providerAccountId String?
  lastSyncedAt  DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  transactions  Transaction[]

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  name      String
  icon      String?
  isSystem  Boolean  @default(false)

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
}

model Transaction {
  id            String          @id @default(uuid())
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId     String
  category      Category?       @relation(fields: [categoryId], references: [id])
  categoryId    String?

  description   String
  merchant      String?
  amount        Decimal         @db.Decimal(18, 2)
  type          TransactionType
  occurredAt    DateTime

  // Provider-side identifiers, used to dedupe on sync.
  providerTxnId String?

  // Categorization provenance: "rule", "ai", "user"
  categorizedBy String?
  categoryConfidence Decimal?  @db.Decimal(4, 3)

  createdAt     DateTime        @default(now())

  @@index([accountId])
  @@index([categoryId])
  @@unique([accountId, providerTxnId])
}

model Budget {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  month      Int
  year       Int
  limit      Decimal  @db.Decimal(18, 2)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
}

model Goal {
  id            String     @id @default(uuid())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(18, 2)
  currentAmount Decimal    @default(0) @db.Decimal(18, 2)
  targetDate    DateTime?
  status        GoalStatus @default(ACTIVE)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}
